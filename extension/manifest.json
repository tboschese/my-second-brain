{
  "manifest_version": 3,
  "name": "Segundo Cérebro — Captura (Kindle · YouTube · Artigos)",
  "short_name": "Segundo Cérebro",
  "version": "1.0.0",
  "description": "Captura páginas do Kindle, vídeos do YouTube e artigos da web para o seu Segundo Cérebro em localhost:3000.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "*://read.amazon.com/*",
    "*://read.amazon.com.br/*",
    "*://read.amazon.co.uk/*",
    "*://read.amazon.de/*",
    "*://read.amazon.fr/*",
    "*://read.amazon.es/*",
    "*://read.amazon.it/*",
    "*://read.amazon.co.jp/*",
    "*://read.amazon.com.au/*",
    "*://read.amazon.com.mx/*",
    "*://read.amazon.in/*",
    "*://read.amazon.ca/*",
    "*://www.youtube.com/*",
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Segundo Cérebro — Capturar esta página"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content/webapp-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://read.amazon.com/*",
        "*://read.amazon.com.br/*",
        "*://read.amazon.co.uk/*",
        "*://read.amazon.de/*",
        "*://read.amazon.fr/*",
        "*://read.amazon.es/*",
        "*://read.amazon.it/*",
        "*://read.amazon.co.jp/*",
        "*://read.amazon.com.au/*",
        "*://read.amazon.com.mx/*",
        "*://read.amazon.in/*",
        "*://read.amazon.ca/*"
      ],
      "js": ["content/kindle.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    }
  ]
}
